                "exclude": ["**/[Bb]in/**", "**/[Oo]bj/**", ".LMS.config/**/*", "**/*.lock.json", "**/.git/**", "**/.DS_Store/**", "**/*.db/**", "**/.vscode/**"]
            }
          ]
